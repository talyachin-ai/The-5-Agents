# ===========================================
# The 5 Agents — Environment Variables
# העתק קובץ זה ל-.env ומלא את הערכים האמיתיים
# cp .env.example .env
# ===========================================

# --- Anthropic (ראובן + הצוות / טקסט - יעל) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-8

# --- יצירת תמונות (יובל) ---
# מפתח OpenAI ליצירת תמונות (סקיל gpt-image-gen, מודל gpt-image-2)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# מפתח/מודל גנריים לשירות תמונות (אופציונלי, אם משתמשים בספק אחר)
IMAGE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
IMAGE_MODEL=

# --- מחקר וחיפוש (חן) ---
# מפתח לשירות חיפוש/מחקר באינטרנט
SEARCH_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# --- הגדרות כלליות ---
LOG_LEVEL=info
